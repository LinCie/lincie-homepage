---
import "../styles/global.css";

import caveatFontUrl from "@fontsource-variable/caveat/files/caveat-latin-wght-normal.woff2?url";
import GardenNav from "../components/GardenNav.astro";
import TextureOverlay from "../components/TextureOverlay.astro";

interface BreadcrumbItem {
	name: string;
	href: string;
}

interface Props {
	title?: string;
	description?: string;
	image?: string;
	noindex?: boolean;
	breadcrumbs?: BreadcrumbItem[];
}

const siteName = "LinCie's Garden";
const defaultTitle = "LinCie — A Little Corner of the Internet";

const {
	title = defaultTitle,
	description = "Welcome to my living garden — a personal website that shifts with time of day and seasons. Hand-crafted with warmth and care.",
	image = "https://lincie.me/og-image.png",
	noindex = false,
	breadcrumbs = [],
} = Astro.props;

const pageTitle = title === defaultTitle ? title : `${title} | ${siteName}`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Aldio Fernanda",
	alternateName: "LinCie",
	url: "https://lincie.me",
	email: "contact@lincie.me",
	jobTitle: "Full Stack Web Developer",
	sameAs: [
		"https://github.com/lincie",
		"https://www.linkedin.com/in/aldiofernanda/",
		"https://www.instagram.com/aldio_frd/",
		"https://open.spotify.com/user/31oyxnawj25zik4xbwog3emhjsmi",
	],
	knowsAbout: [
		"Astro", "TypeScript", "React", "Tailwind CSS",
		"Node.js", "ElysiaJS", "PostgreSQL", "SQLite",
		"Discord.js", "Lavalink", "MinIO",
	],
	description: "Someone who smiles easy and moves gently through the world. Builder of living gardens on the internet.",
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: siteName,
	url: "https://lincie.me",
	description: "A living garden that mirrors the real world across time of day and seasons — a warm, handmade personal website by LinCie.",
};

const webPageSchema = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	name: pageTitle,
	description: description,
	url: canonicalURL.href,
	isPartOf: {
		"@type": "WebSite",
		url: "https://lincie.me",
		name: siteName,
	},
	about: {
		"@type": "Person",
		name: "Aldio Fernanda",
	},
};

const breadcrumbSchema = breadcrumbs.length > 0 ? {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: breadcrumbs.map((item, i) => ({
		"@type": "ListItem",
		position: i + 1,
		name: item.name,
		item: new URL(item.href, Astro.site).href,
	})),
} : null;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="viewport" content="width=device-width, viewport-fit=cover" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="author" content="Aldio Fernanda" />
		<meta name="theme-color" content="#b8e6d0" />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<link rel="canonical" href={canonicalURL.href} />
		<link rel="manifest" href="/site.webmanifest" />

		<link rel="me" href="https://github.com/lincie" />
		<link rel="me" href="https://www.linkedin.com/in/aldiofernanda/" />
		<link rel="me" href="https://www.instagram.com/aldio_frd/" />
		<link rel="me" href="https://open.spotify.com/user/31oyxnawj25zik4xbwog3emhjsmi" />

		<title>{pageTitle}</title>

		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:image" content={image} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:locale" content="en_US" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />

		<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
		{Astro.url.pathname === "/" && (
			<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
		)}
		<script is:inline type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
		{breadcrumbSchema && (
			<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		)}

		<link rel="preload" href={caveatFontUrl} as="font" type="font/woff2" crossorigin />
		<script is:inline>
			(function(){var h=new Date().getHours(),t='night';if(h>=5&&h<12)t='morning';else if(h>=12&&h<17)t='afternoon';else if(h>=17&&h<21)t='evening';document.documentElement.setAttribute('data-time',t);var m=new Date().getMonth(),s='winter';if(m>=2&&m<=4)s='spring';else if(m>=5&&m<=7)s='summer';else if(m>=8&&m<=10)s='autumn';document.documentElement.setAttribute('data-season',s)})();
		</script>
	</head>
	<body class="font-body">
		<a class="skip-link" href="#main-content">Skip to content</a>
		<canvas id="season-particles" class="season-particles" aria-hidden="true"></canvas>
		<TextureOverlay />
		<script>
			import "../scripts/world.ts";
			import "../scripts/seasonal-particles.ts";
			import "../scripts/meadow.ts";
		</script>
		<GardenNav />
		<main id="main-content" class="transition-garden" style="flex: 1;">
			<slot />
		</main>
		<footer class="garden-footer" style="color: var(--color-muted); text-align: center; padding-block: var(--space-element);">
			<p class="text-sm">&mdash; LinCie's garden &mdash;</p>
			<a href="/diary" class="secret-path" aria-label="A hidden path">
				<span class="secret-path__leaf" aria-hidden="true">&#10047;</span>
				<span class="secret-path__label">a hidden path...</span>
			</a>
		</footer>
	</body>
</html>

<style is:global>
	.skip-link {
		position: absolute;
		inset-inline-start: -9999px;
		padding: 0.5rem 1rem;
		background-color: var(--color-surface);
		color: var(--color-text);
		z-index: 100;
		border-radius: var(--radius-soft);
		font-family: var(--font-body);
	}

	.skip-link:focus {
		inset-inline-start: 1rem;
		inset-block-start: 1rem;
	}

	body {
		padding-inline: clamp(1.25rem, 4vw, 2.5rem);
	}

	.garden-container {
		width: 100%;
		max-width: var(--max-width);
		margin-inline: auto;
	}

	.garden-row {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		gap: var(--space-element);
	}

	.garden-row--center {
		justify-content: center;
		text-align: center;
		align-items: center;
	}

	.garden-row--spread {
		justify-content: space-between;
	}

	.organic-card {
		background-color: var(--color-surface);
		border-radius: var(--radius-soft);
		padding: clamp(1.25rem, 3vw, 2rem);
		transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease, background-color 1.5s ease;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
	}

	.tilt-left:hover {
		transform: translateY(-3px) rotate(-2.5deg);
	}

	.tilt-right:hover {
		transform: translateY(-3px) rotate(2.5deg);
	}

	.organic-card:hover {
		box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
	}

	.organic-divider {
		width: 60px;
		height: 3px;
		background-color: var(--color-accent);
		border-radius: 2px;
		opacity: 0.5;
	}

	.secret-path {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin-top: 0.5rem;
		font-size: 0.7rem;
		color: var(--color-muted);
		opacity: 0.6;
		text-decoration: none;
		padding: 0.75rem 1rem;
		margin-left: -1rem;
		border-radius: var(--radius-pill);
		min-height: 2.75rem;
		transition: opacity 0.5s ease, color 0.3s ease, background-color 0.3s ease;
	}

	.secret-path:hover {
		opacity: 1;
		color: var(--color-accent);
		background-color: color-mix(in srgb, var(--color-accent) 8%, transparent);
	}

	.secret-path:focus-visible {
		opacity: 1;
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	.secret-path__leaf {
		font-size: 0.85rem;
		opacity: 0.7;
		animation: secret-gentle-sway 4s ease-in-out infinite;
		will-change: transform;
	}

	@keyframes secret-gentle-sway {
		0%, 100% { transform: rotate(0deg); }
		25% { transform: rotate(5deg); }
		75% { transform: rotate(-5deg); }
	}

	html.is-changing .transition-garden {
		transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1), transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
		opacity: 1;
		transform: translateY(0);
	}

	html.is-animating .transition-garden {
		opacity: 0;
		transform: translateY(8px);
	}

	@media (prefers-reduced-motion: reduce) {
		html.is-changing .transition-garden {
			transition: none;
		}
	}
</style>
