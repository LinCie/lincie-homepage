---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const { title = "LinCie", description = "A little corner of the internet" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="font-body">
		<script>
			import "../scripts/time-of-day.ts";
			import "../scripts/season.ts";
		</script>
		<slot />
	</body>
</html>

<style is:global>
	body {
		padding-inline: clamp(1.25rem, 4vw, 2.5rem);
	}

	.garden-container {
		width: 100%;
		max-width: var(--max-width);
		margin-inline: auto;
	}

	.garden-row {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		gap: var(--space-element);
	}

	.garden-row--center {
		justify-content: center;
		text-align: center;
		align-items: center;
	}

	.garden-row--spread {
		justify-content: space-between;
	}

	.organic-card {
		background-color: var(--color-surface);
		border-radius: var(--radius-soft);
		padding: clamp(1.25rem, 3vw, 2rem);
		transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 1.5s ease;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
	}

	.organic-card:hover {
		transform: translateY(-3px) rotate(-0.5deg);
		box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
	}

	.organic-divider {
		width: 60px;
		height: 3px;
		background-color: var(--color-accent);
		border-radius: 2px;
		opacity: 0.5;
	}
</style>
