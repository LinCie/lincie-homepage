---
interface Props {
	class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class={`flower ${className}`}>
	<div class="flower__sway">
		<div class="flower__bloom">
			{[...Array(6)].map((_, i) => (
				<div
					class="flower__petal"
					style={`--petal-rotation: ${i * 60}deg;`}
				/>
			))}
			<div class="flower__center" />
		</div>
	</div>
	<div class="flower__stem" />
	<div class="flower__leaf flower__leaf--left" />
	<div class="flower__leaf flower__leaf--right" />
</div>

<style>
	.flower {
		--petal-size: var(--flower-petal-size, 30px);
		--center-size: 18px;
		--stem-height: 60px;
		--sway-speed: var(--flower-sway-speed, 4s);
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		width: 80px;
		height: calc(var(--stem-height) + 80px);
	}

	.flower__sway {
		animation: sway var(--sway-speed) ease-in-out infinite;
		transform-origin: bottom center;
		z-index: 1;
		will-change: transform;
	}

	.flower__bloom {
		position: relative;
		width: 70px;
		height: 70px;
		transform: rotate(var(--flower-bloom-rotate, 0deg));
		transition: transform 1.5s ease;
		will-change: transform;
	}

	.flower__petal {
		position: absolute;
		width: var(--petal-size);
		height: var(--petal-size);
		background-color: var(--color-flower);
		border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
		top: 50%;
		left: 50%;
		margin-left: calc(var(--petal-size) / -2);
		margin-top: calc(var(--petal-size) / -2);
		--petal-distance: var(--flower-petal-distance, 28px);
		transform: rotate(var(--petal-rotation)) translateY(calc(-1 * var(--petal-distance)));
		opacity: var(--color-flower-opacity, 0.85);
		transition: background-color 1.5s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease, width 1.5s ease, height 1.5s ease;
	}

	.flower__center {
		position: absolute;
		width: var(--center-size);
		height: var(--center-size);
		background-color: var(--color-flower-center);
		border-radius: 50%;
		top: 50%;
		left: 50%;
		margin-left: calc(var(--center-size) / -2);
		margin-top: calc(var(--center-size) / -2);
		z-index: 1;
		transition: background-color 1.5s ease;
	}

	.flower__stem {
		width: 3px;
		height: var(--stem-height);
		background-color: var(--color-leaf, #6dcc7b);
		border-radius: 2px;
		margin-top: 4px;
	}

	.flower__leaf {
		position: absolute;
		width: 22px;
		height: 11px;
		background-color: var(--color-leaf, #6dcc7b);
		border-radius: 0 50% 50% 0;
		top: calc(80px + 25px);
		opacity: 0.8;
		transition: background-color 1.5s ease;
	}

	.flower__leaf--left {
		left: 32px;
		transform: rotate(-30deg);
		border-radius: 50% 0 0 50%;
	}

	.flower__leaf--right {
		right: 32px;
		transform: rotate(30deg);
	}

	.flower:hover .flower__petal {
		opacity: 1;
		--petal-distance: calc(var(--flower-petal-distance, 28px) + 8px);
	}

	.flower:hover .flower__sway {
		animation-duration: 2.5s;
	}

	@keyframes sway {
		0%,
		100% {
			transform: rotate(-3deg);
		}
		50% {
			transform: rotate(3deg);
		}
	}

	[data-season="spring"] .flower__bloom {
		animation: spring-bloom 6s ease-in-out infinite;
	}

	@keyframes spring-bloom {
		0%,
		100% {
			transform: rotate(0deg) scale(1);
		}
		50% {
			transform: rotate(2deg) scale(1.07);
		}
	}

	[data-season="summer"] .flower__bloom {
		animation: summer-full 7s ease-in-out infinite;
	}

	@keyframes summer-full {
		0%,
		100% {
			transform: rotate(0deg) scale(1);
		}
		25% {
			transform: rotate(3deg) scale(1.05);
		}
		75% {
			transform: rotate(-2deg) scale(1.03);
		}
	}

	[data-season="autumn"] .flower__bloom {
		animation: autumn-sway 8s ease-in-out infinite;
	}

	@keyframes autumn-sway {
		0%,
		100% {
			transform: rotate(-8deg) translateY(20px);
		}
		50% {
			transform: rotate(-4deg) translateY(20px);
		}
	}

	[data-season="autumn"] .flower__petal:nth-child(1) {
		transform: rotate(calc(var(--petal-rotation) + 12deg)) translateY(calc(-1 * var(--petal-distance))) scale(0.9);
	}

	[data-season="autumn"] .flower__petal:nth-child(2) {
		transform: rotate(calc(var(--petal-rotation) - 8deg)) translateY(calc(-1 * var(--petal-distance))) scale(0.95);
	}

	[data-season="autumn"] .flower__petal:nth-child(3) {
		transform: rotate(calc(var(--petal-rotation) + 18deg)) translateY(calc(-1 * var(--petal-distance) + 5px)) scale(0.85);
		opacity: calc(var(--color-flower-opacity) * 0.7);
	}

	[data-season="autumn"] .flower__petal:nth-child(4) {
		transform: rotate(calc(var(--petal-rotation) - 15deg)) translateY(calc(-1 * var(--petal-distance) + 8px)) scale(0.8);
		opacity: calc(var(--color-flower-opacity) * 0.55);
	}

	[data-season="autumn"] .flower__petal:nth-child(5) {
		transform: rotate(calc(var(--petal-rotation) + 10deg)) translateY(calc(-1 * var(--petal-distance))) scale(0.92);
	}

	[data-season="autumn"] .flower__petal:nth-child(6) {
		transform: rotate(calc(var(--petal-rotation) - 20deg)) translateY(calc(-1 * var(--petal-distance) + 4px)) scale(0.88);
		opacity: calc(var(--color-flower-opacity) * 0.65);
	}

	[data-season="winter"] .flower__bloom {
		animation: winter-rest 12s ease-in-out infinite;
	}

	@keyframes winter-rest {
		0%,
		100% {
			transform: rotate(-12deg) scale(0.8) translateY(32px);
		}
		50% {
			transform: rotate(-12deg) scale(0.84) translateY(32px);
		}
	}

	.flower__bloom {
		animation: flower__bloom 4s ease-in-out infinite;
	}

	@keyframes flower__bloom {
		0%,
		100% {
			scale: 1;
		}
		50% {
			scale: 1.02;
		}
	}
</style>
