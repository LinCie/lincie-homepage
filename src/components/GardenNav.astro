---
interface NavLink {
	href: string;
	label: string;
}

const links: NavLink[] = [
	{ href: '/', label: 'Garden' },
	{ href: '/about', label: 'About' },
	{ href: '/portfolio', label: 'Greenhouse' },
	{ href: '/contact', label: 'Say Hello' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav class="garden-nav" aria-label="Garden paths">
	{links.map(link => (
		<a
			href={link.href}
			class:list={['garden-nav__link', currentPath === link.href ? 'garden-nav__link--active' : '']}
			aria-current={currentPath === link.href ? 'page' : undefined}
		>
			{link.label}
		</a>
	))}
</nav>

<style>
	.garden-nav {
		display: flex;
		justify-content: center;
		gap: 0.25rem;
		padding: 0.5rem 1rem;
		position: sticky;
		top: 0;
		z-index: 10;
		background: color-mix(in oklch, var(--color-bg) 80%, transparent);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	.garden-nav__link {
		font-size: 0.8rem;
		color: var(--color-muted);
		text-decoration: none;
		padding: 0.4rem 0.75rem;
		border-radius: var(--radius-pill);
		transition: color 0.3s ease, background-color 0.3s ease;
		min-height: 2.75rem;
		display: inline-flex;
		align-items: center;
	}

	.garden-nav__link:hover {
		color: var(--color-heading);
		background-color: var(--color-accent-soft);
	}

	.garden-nav__link:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	.garden-nav__link--active {
		color: var(--color-heading);
		background-color: var(--color-accent-soft);
	}

	@media (max-width: 24rem) {
		.garden-nav {
			flex-wrap: wrap;
		}

		.garden-nav__link {
			flex: 1 1 auto;
			justify-content: center;
		}
	}
</style>
