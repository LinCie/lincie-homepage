---
import Layout from "../layouts/Layout.astro";
import BackLink from "../components/BackLink.astro";
import DiaryEntry from "../components/DiaryEntry.astro";
import { diaryEntries } from "../data/diary";
---

<Layout
	title="Secret Garden — LinCie"
	description="A quiet place for thoughts that don't fit anywhere else."
	noindex={true}
>
	<section class="garden-container" aria-label="Diary">
		<BackLink />
		<h1 class="font-heading text-5xl sm:text-6xl mt-6 mb-4" style="color: var(--color-heading)">
			My Secret Garden
		</h1>
		<div class="organic-divider my-6" />
		<p class="text-lg mb-8 max-w-lg diary-welcome" style="color: var(--color-muted); line-height: 1.8;">
			You found it.
		</p>
		<p class="text-sm mb-10 max-w-md" style="color: var(--color-muted); opacity: 0.75; line-height: 1.8;">
			A quiet place for thoughts that don't fit anywhere else.
		</p>

		<div class="diary-list">
			{diaryEntries.map((entry) => (
				<DiaryEntry
					date={entry.date}
					title={entry.title}
					body={entry.body}
				/>
			))}
		</div>
	</section>
</Layout>

<style>
	.diary-list {
		max-width: 32rem;
		margin-top: 1rem;
	}

	.diary-welcome {
		animation: gentle-reveal 1.2s ease-out;
	}

	@keyframes gentle-reveal {
		from {
			opacity: 0;
			transform: translateY(6px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
