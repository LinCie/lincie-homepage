---
import Layout from "../layouts/Layout.astro";
import Flower from "../components/Flower.astro";
---

<Layout title="Lost in the Garden — LinCie">
	<section class="flex flex-col items-center justify-center min-h-[80dvh] text-center">
		<div class="flower-404">
			<Flower class="scale-100 sm:scale-110" />
		</div>
		<h1 class="font-heading text-4xl sm:text-5xl mt-8 mb-3" style="color: var(--color-heading)">
			Oh no, a dead end...
		</h1>
		<div class="organic-divider my-4" />
		<p class="text-lg max-w-md mb-8" style="color: var(--color-muted); line-height: 1.7;">
			This path doesn't seem to lead anywhere. The garden is vast, but every path has a destination — this one just... doesn't.
		</p>
		<a
			href="/"
			class="inline-block px-6 py-3 font-heading text-lg no-underline"
			style="background-color: var(--color-accent-soft); border-radius: var(--radius-pill); color: var(--color-text); transition: background-color 0.3s ease;"
		>
			Let's go back to the garden
		</a>
	</section>
</Layout>

<style>
	.flower-404 {
		animation: gentle-droop 4s ease-in-out infinite;
		filter: saturate(0.6) brightness(0.9);
	}

	.flower-404 :global(.flower__bloom) {
		transform: rotate(-18deg) translateY(10px);
	}

	.flower-404 :global(.flower__petal) {
		opacity: calc(var(--color-flower-opacity, 0.85) * 0.65);
	}

	@keyframes gentle-droop {
		0%, 100% { transform: rotate(0deg) translateY(0); }
		30% { transform: rotate(3deg) translateY(2px); }
		70% { transform: rotate(-2deg) translateY(5px); }
	}
</style>
