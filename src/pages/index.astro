---
import Layout from "../layouts/Layout.astro";
import Flower from "../components/Flower.astro";
import OrganicCard from "../components/OrganicCard.astro";
---

<Layout>
	<section class="flex flex-col items-center justify-center min-h-[80dvh] text-center">
		<Flower class="mb-6 scale-125 sm:scale-150" />
		<h1 class="font-heading text-5xl sm:text-6xl" style="color: var(--color-heading)">
			Hello, I'm LinCie
		</h1>
		<div class="organic-divider my-6" />
		<p class="text-lg max-w-md" style="color: var(--color-muted)">
			Welcome to my little corner of the internet.
		</p>
		<div class="mt-8 px-4 py-2 rounded-full" style="background-color: var(--color-accent-soft)">
			<span class="text-sm" style="color: var(--color-accent-mid)">a garden in progress</span>
		</div>
	</section>

	<section class="garden-container">
		<div class="garden-row garden-row--spread">
			<OrganicCard tilt="left" class="flex-1 min-w-[14rem]">
				<h2 class="font-heading text-2xl mb-2" style="color: var(--color-heading)">
					About
				</h2>
				<p class="text-sm" style="color: var(--color-muted)">
					A little story about me, planted here with care.
				</p>
			</OrganicCard>
			<OrganicCard tilt="right" class="flex-1 min-w-[14rem] mt-6 sm:mt-0">
				<h2 class="font-heading text-2xl mb-2" style="color: var(--color-heading)">
					Portfolio
				</h2>
				<p class="text-sm" style="color: var(--color-muted)">
					Things I've grown and nurtured along the way.
				</p>
			</OrganicCard>
		</div>
	</section>
</Layout>
