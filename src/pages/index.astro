---
import Layout from "../layouts/Layout.astro";
import Flower from "../components/Flower.astro";
import OrganicCard from "../components/OrganicCard.astro";
---

<Layout>
	<section class="flex flex-col items-center justify-center min-h-[80dvh] text-center" aria-label="Introduction">
		<Flower class="mb-6 scale-125 sm:scale-150" />
		<h1 class="font-heading text-5xl sm:text-6xl" style="color: var(--color-heading)">
			<span class="greeting-text">Hello</span>, I'm LinCie
		</h1>
		<div class="organic-divider my-6" />
		<p class="text-lg max-w-md" style="color: var(--color-muted)">
			Welcome to my little corner of the internet.
		</p>
		<div class="mt-8 px-4 py-2" style="background-color: var(--color-accent-soft); border-radius: var(--radius-pill)">
			<span class="text-sm" style="color: var(--color-muted)">a garden in progress</span>
		</div>
	</section>

	<nav class="garden-container" aria-label="Explore the garden">
		<p class="explore-invite font-heading text-xl sm:text-2xl" style="color: var(--color-muted)">
			Where would you like to wander?
		</p>
		<div class="explore-garden">
			<a href="/portfolio" class="explore-card explore-card--primary no-underline">
				<OrganicCard class="greenhouse-card">
					<h2 class="font-heading text-3xl sm:text-4xl mb-3" style="color: var(--color-heading)">
						My Greenhouse
					</h2>
					<p style="color: var(--color-muted)">
						Things I've grown and nurtured along the way.
					</p>
				</OrganicCard>
			</a>
			<div class="explore-secondary">
				<a href="/about" class="explore-card no-underline">
					<OrganicCard tilt="left">
						<h2 class="font-heading text-2xl mb-2" style="color: var(--color-heading)">
							About
						</h2>
						<p class="text-sm" style="color: var(--color-muted)">
							A little story about me, planted here with care.
						</p>
					</OrganicCard>
				</a>
				<a href="/contact" class="explore-card no-underline">
					<OrganicCard tilt="right">
						<h2 class="font-heading text-2xl mb-2" style="color: var(--color-heading)">
							Say Hello
						</h2>
						<p class="text-sm" style="color: var(--color-muted)">
							Drop me a note — I'd love to hear from you.
						</p>
					</OrganicCard>
				</a>
			</div>
		</div>
	</nav>
</Layout>

<script>
	const greetings: Record<string, string> = {
		morning: 'Good morning',
		afternoon: 'Good afternoon',
		evening: 'Good evening',
		night: 'Hello',
	};

	function updateGreeting() {
		const time = document.documentElement.getAttribute('data-time') || 'morning';
		const greetingEl = document.querySelector('.greeting-text');
		if (greetingEl) {
			greetingEl.textContent = greetings[time] || 'Hello';
		}
	}

	updateGreeting();
	document.documentElement.addEventListener('data-time-change', updateGreeting);

	const observer = new MutationObserver((mutations) => {
		mutations.forEach((mutation) => {
			if (mutation.attributeName === 'data-time') {
				updateGreeting();
			}
		});
	});
	observer.observe(document.documentElement, { attributes: true });
</script>

<style>
	.explore-invite {
		text-align: center;
		margin-bottom: 2rem;
	}

	.explore-garden {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
	}

	.explore-secondary {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
	}

	.explore-card {
		width: 100%;
		max-width: 24rem;
	}

	.explore-card--primary {
		max-width: 28rem;
	}

	.greenhouse-card {
		padding: clamp(1.5rem, 4vw, 2.5rem);
		border-left: 3px solid var(--color-accent);
	}

	.greeting-text {
		display: inline;
		transition: opacity 0.8s ease;
	}

	.explore-card {
		animation: card-grow 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
	}

	.explore-card:nth-child(1) {
		animation-delay: 0.1s;
	}

	.explore-card:nth-child(2) {
		animation-delay: 0.2s;
	}

	.explore-card:nth-child(3) {
		animation-delay: 0.3s;
	}

	@keyframes card-grow {
		from {
			opacity: 0;
			transform: scale(0.95);
		}
		to {
			opacity: 1;
			transform: scale(1);
		}
	}

	@media (min-width: 40rem) {
		.explore-garden {
			flex-direction: row;
			align-items: flex-start;
			gap: var(--space-element);
		}

		.explore-secondary {
			order: 1;
			flex: 0 1 auto;
		}

	.explore-card:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 4px;
		border-radius: var(--radius-soft);
	}

	.explore-card--primary {
			order: 2;
			flex: 1 1 0;
			max-width: 24rem;
			margin-top: 1.5rem;
		}
	}
</style>
