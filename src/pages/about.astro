---
import Layout from "../layouts/Layout.astro";
import BackLink from "../components/BackLink.astro";
import OrganicCard from "../components/OrganicCard.astro";
---

<Layout title="About — LinCie">
	<section class="garden-container" aria-label="About">
		<BackLink />
		<h1 class="font-heading text-5xl sm:text-6xl mt-6 mb-4" style="color: var(--color-heading)">
			About Me
		</h1>
		<div class="organic-divider my-6" />

		<div class="about-content">
			<p class="text-lg mb-4" style="color: var(--color-text); line-height: 1.8;">
				Hi there! I'm LinCie — someone who believes the internet should feel warmer.
				I build things on the web that I hope make people smile, even if just a little.
			</p>
			<p class="mb-6" style="color: var(--color-muted); line-height: 1.8;">
				I like slow mornings, handwritten letters, and the way gardens look right after rain.
				I think good design is the kind you barely notice — it just feels right, like a well-worn path.
			</p>

			<div class="about-highlights">
				<OrganicCard tilt="left" class="about-highlight">
					<h2 class="font-heading text-xl mb-1" style="color: var(--color-heading)">
						What I Do
					</h2>
					<p class="text-sm" style="color: var(--color-muted)">
						I design and build websites and small applications. I care about craft, accessibility, and making things that feel genuinely human.
					</p>
				</OrganicCard>
				<OrganicCard tilt="right" class="about-highlight">
					<h2 class="font-heading text-xl mb-1" style="color: var(--color-heading)">
						What I Love
					</h2>
					<p class="text-sm" style="color: var(--color-muted)">
						Clean code, quiet afternoons, good typography, and projects that start with "wouldn't it be nice if..."
					</p>
				</OrganicCard>
			</div>

			<div class="organic-divider my-8" />

			<p style="color: var(--color-muted); font-style: italic; line-height: 1.7;">
				Thanks for stopping by my little garden. I hope it made your day a tiny bit softer.
			</p>
		</div>
	</section>
</Layout>

<style>
	.about-content {
		max-width: 36rem;
	}

	.about-highlights {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-block: 2rem;
	}

	.about-highlight {
		max-width: 24rem;
	}

	@media (min-width: 40rem) {
		.about-highlights {
			flex-direction: row;
		}
	}
</style>
