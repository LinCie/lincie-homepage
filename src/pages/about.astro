---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About — LinCie">
	<section class="garden-container" aria-label="About">
		<a href="/" class="back-link" style="color: var(--color-muted); text-decoration: none;">
			&larr; back to the garden
		</a>
		<h1 class="font-heading text-5xl sm:text-6xl mt-6 mb-4" style="color: var(--color-heading)">
			About Me
		</h1>
		<div class="organic-divider my-6" />
		<p class="text-lg max-w-md" style="color: var(--color-muted)">
			This is where my story will bloom. A little corner to share who I am, what I love, and the things that make me, me.
		</p>
		<p class="mt-4 max-w-md" style="color: var(--color-muted)">
			Planted with care. Still growing.
		</p>
	</section>
</Layout>
