---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Portfolio — LinCie">
	<section class="garden-container" aria-label="Portfolio">
		<a href="/" class="back-link" style="color: var(--color-muted); text-decoration: none;">
			&larr; back to the garden
		</a>
		<h1 class="font-heading text-5xl sm:text-6xl mt-6 mb-4" style="color: var(--color-heading)">
			Portfolio
		</h1>
		<div class="organic-divider my-6" />
		<p class="text-lg max-w-md" style="color: var(--color-muted)">
			This greenhouse is still being built. Soon it will hold the projects I've grown and nurtured — each one a little seed that became something more.
		</p>
		<p class="mt-4 max-w-md" style="color: var(--color-muted)">
			Come back soon to see what's sprouting.
		</p>
	</section>
</Layout>
